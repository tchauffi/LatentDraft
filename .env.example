# LatentDraft server configuration.
#
# NOTE: the server does NOT load this file — it reads plain environment
# variables. Copy what you need and `source` it, `export` the variables,
# or prefix them on the command line:  ANTHROPIC_API_KEY=... npm run dev

# Where project folders live
#export PROJECTS_ROOT="$HOME/LatentDraft"

# API server port
#export PORT=5174

# Bind address. Keep localhost — run_python executes arbitrary code and the
# API has no authentication. Never expose this on an untrusted network.
#export HOST=127.0.0.1

# Kill a Tectonic compile after this many ms
#export COMPILE_TIMEOUT_MS=300000

# Path to the Tectonic binary (default: ./bin/tectonic, fetched by npm run setup)
#export TECTONIC_BIN=./bin/tectonic

# --- Providers -------------------------------------------------------------

# Ollama (local, the default provider)
#export OLLAMA_BASE_URL=http://localhost:11434
#export OLLAMA_NUM_CTX=16384

# Ollama Cloud (https://ollama.com API key; OLLAMA_API_KEY works too)
#export OLLAMA_CLOUD_API_KEY=
#export OLLAMA_CLOUD_MODELS=gpt-oss:120b,qwen3-coder:480b

# Any OpenAI-compatible endpoint (OpenAI, LM Studio, vLLM, OpenRouter, ...)
#export OPENAI_BASE_URL=https://api.openai.com/v1
#export OPENAI_API_KEY=
#export OPENAI_MODELS=gpt-4o-mini
#export OPENAI_CONTEXT_LENGTH=128000

# Anthropic
#export ANTHROPIC_API_KEY=
#export ANTHROPIC_MODELS=claude-opus-4-8,claude-sonnet-5

# --- Tools -----------------------------------------------------------------

# Interpreter for run_python / view_pdf / ats_check
# (default: server/.venv/bin/python, created by npm run setup)
#export PYTHON_BIN=

# web_search backends: Tavily if set, else Brave if set, else DuckDuckGo
#export TAVILY_API_KEY=
#export BRAVE_API_KEY=
